generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserSession {
  id              String   @id @default(cuid())
  discordUserId    String   @unique
  accessToken      String
  postizUserId     String?
  stripeCustomerId String?
  authenticatedAt DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("user_sessions")
}

model BillingAction {
  id              String   @id @default(cuid())
  discordUserId   String
  stripeInvoiceId String   @unique
  action          String   // "refund" or "discount"
  createdAt       DateTime @default(now())

  @@map("billing_actions")
}

model PendingAuth {
  id               String   @id @default(cuid())
  state            String   @unique
  discordUserId    String
  channelId        String
  interactionToken String?
  createdAt        DateTime @default(now())

  @@map("pending_auths")
}

model SupportThread {
  id               String    @id @default(cuid())
  threadId         String    @unique
  guildId          String
  lastActivityAt   DateTime  @default(now())
  warningSentAt    DateTime?
  warningMessageId String?
  closedAt         DateTime?
  createdAt        DateTime  @default(now())

  @@map("support_threads")
}
